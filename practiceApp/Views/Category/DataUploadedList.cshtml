@model practiceApp.Models.DataUploadListModel

<h2>Uploaded Files</h2>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <input type="text" name="searchEmail" value="@Model.SearchEmail" class="form-control" placeholder="Search by Email" />
    </div>
    <div class="col-md-3">
        <input type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? "")" class="form-control" />
    </div>
    <div class="col-md-3">
        <input type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? "")" class="form-control" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

@if (Model.DataUploads != null && Model.DataUploads.Any())
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Content Type</th>
                <th>Sent To Email</th>
                <th>Uploaded At</th>
                <th>Uploaded By</th>
                <th>Download</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var file in Model.DataUploads)
            {
                <tr>
                    <td>@file.FileName</td>
                    <td>@file.ContentType</td>
                    <td>@file.SentToEmail</td>
                    <td>@file.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@file.UploadedBy</td>
                    <td>
                        <a asp-action="Download" asp-route-id="@file.Id" class="btn btn-sm btn-success">
                            Download
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No files found.</p>
}
